# ASL Study Tool - Server Environment Variables Template

# Port the Express server will listen on
PORT=8080

# Connection string for the PostgreSQL database (local or cloud)
DATABASE_URL=postgresql://asl_user:asl_password@localhost:5432/asl_study_tool

# JWT secrets for session authentication (generate strong random keys in production)
JWT_SECRET=supersecretjwtaccesskeychangemeinprod123
JWT_REFRESH_SECRET=supersecretjwtrefreshkeychangemeinprod456

# URL and shared secret of the FastAPI AI microservice
AI_SERVICE_URL=http://localhost:8000
AI_SERVICE_SECRET=a_strong_random_secret_for_internal_auth

# CORS allowed origin
CORS_ORIGIN=http://localhost:3000
